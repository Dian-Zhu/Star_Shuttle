<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>简洁提示框</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: #f5f5f5;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 40px 20px;
        }
        
        .demo-area {
            max-width: 400px;
            width: 100%;
        }
        
        h1 {
            text-align: center;
            color: #333;
            margin-bottom: 30px;
            font-weight: 400;
        }
        
        .btn {
            width: 100%;
            padding: 12px;
            margin-bottom: 10px;
            border: 1px solid #ddd;
            background: white;
            color: #333;
            font-size: 14px;
            cursor: pointer;
            border-radius: 4px;
            transition: all 0.2s;
        }
        
        .btn:hover {
            background: #f8f8f8;
        }
        
        .success { border-left: 3px solid #28a745; }
        .warning { border-left: 3px solid #ffc107; }
        .error { border-left: 3px solid #dc3545; }
        .info { border-left: 3px solid #17a2b8; }
        
        /* 提示框容器 */
        #alert-container {
            position: fixed;
            top: 20px;
            right: 20px;
            max-width: 300px;
            z-index: 1000;
        }
        
        /* 提示框样式 */
        .alert {
            background: white;
            padding: 12px 16px;
            margin-bottom: 10px;
            border-radius: 4px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            border-left: 4px solid #ccc;
            display: flex;
            align-items: center;
            animation: slideIn 0.3s ease;
        }
        
        .alert.hiding {
            animation: fadeOut 0.3s ease forwards;
        }
        
        .alert.success { border-color: #28a745; }
        .alert.warning { border-color: #ffc107; }
        .alert.error { border-color: #dc3545; }
        .alert.info { border-color: #17a2b8; }
        
        .alert-content {
            flex: 1;
            font-size: 14px;
            color: #333;
        }
        
        .close-btn {
            background: none;
            border: none;
            color: #999;
            font-size: 20px;
            cursor: pointer;
            padding: 0 0 0 10px;
            line-height: 1;
        }
        
        .close-btn:hover {
            color: #666;
        }
        
        /* 模态框样式 */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.5);
            z-index: 1001;
            align-items: center;
            justify-content: center;
        }
        
        .modal-content {
            background: white;
            padding: 30px;
            border-radius: 4px;
            max-width: 400px;
            width: 90%;
        }
        
        .modal-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 15px;
            color: #333;
        }
        
        .modal-message {
            font-size: 14px;
            color: #666;
            margin-bottom: 20px;
            line-height: 1.5;
        }
        
        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
        }
        
        .modal-btn {
            padding: 8px 16px;
            border: 1px solid #ddd;
            background: white;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
        }
        
        .modal-btn.primary {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        
        /* 动画 */
        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(100%);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @keyframes fadeOut {
            from {
                opacity: 1;
                transform: translateX(0);
            }
            to {
                opacity: 0;
                transform: translateX(100%);
            }
        }
    </style>
</head>
<body>
    <div class="demo-area">
        <h1>提示框演示</h1>
        
        <button class="btn success" onclick="showAlert('success')">
            成功提示
        </button>
        
        <button class="btn warning" onclick="showAlert('warning')">
            警告提示
        </button>
        
        <button class="btn error" onclick="showAlert('error')">
            错误提示
        </button>
        
        <button class="btn info" onclick="showAlert('info')">
            信息提示
        </button>
        
        <button class="btn" onclick="showModal()" style="margin-top: 20px;">
            确认对话框
        </button>
    </div>

    <!-- 提示框容器 -->
    <div id="alert-container"></div>

    <!-- 模态框 -->
    <div id="modal" class="modal">
        <div class="modal-content">
            <div class="modal-title">确认操作</div>
            <div class="modal-message">
                您确定要执行此操作吗？此操作不可撤销。
            </div>
            <div class="modal-actions">
                <button class="modal-btn" onclick="closeModal()">取消</button>
                <button class="modal-btn primary" onclick="confirmAction()">确认</button>
            </div>
        </div>
    </div>

    <script>
        // 提示框配置
        const config = {
            success: {
                message: '操作已成功完成',
                duration: 3000
            },
            warning: {
                message: '请注意检查相关内容',
                duration: 4000
            },
            error: {
                message: '操作失败，请重试',
                duration: 5000
            },
            info: {
                message: '这是提示信息',
                duration: 3000
            }
        };

        // 显示提示框
        function showAlert(type) {
            const container = document.getElementById('alert-container');
            
            // 创建提示框元素
            const alert = document.createElement('div');
            alert.className = `alert ${type}`;
            alert.innerHTML = `
                <div class="alert-content">${config[type].message}</div>
                <button class="close-btn" onclick="closeAlert(this)">×</button>
            `;
            
            container.appendChild(alert);
            
            // 自动关闭
            setTimeout(() => {
                if (alert.parentNode) {
                    closeAlert(alert.querySelector('.close-btn'));
                }
            }, config[type].duration);
        }

        // 关闭提示框
        function closeAlert(btn) {
            const alert = btn.closest('.alert');
            alert.classList.add('hiding');
            
            setTimeout(() => {
                if (alert.parentNode) {
                    alert.parentNode.removeChild(alert);
                }
            }, 300);
        }

        // 模态框功能
        function showModal() {
            document.getElementById('modal').style.display = 'flex';
        }

        function closeModal() {
            document.getElementById('modal').style.display = 'none';
        }

        function confirmAction() {
            closeModal();
            showAlert('success');
        }

        // 点击模态框外部关闭
        document.getElementById('modal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });

        // ESC键关闭模态框
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeModal();
            }
        });
    </script>
</body>
</html>